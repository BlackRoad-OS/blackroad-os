# ============================================================================
# BlackRoad OS - Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================================

# =============================================================================
# CORE APPLICATION
# =============================================================================
NODE_ENV=development
PORT=3000
SERVICE_NAME=blackroad-os
ENVIRONMENT=development

# =============================================================================
# DEPLOYMENT PLATFORMS
# =============================================================================

# Railway (https://railway.app)
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=

# Cloudflare (https://dash.cloudflare.com)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# Vercel (https://vercel.com)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Digital Ocean (https://cloud.digitalocean.com)
DIGITALOCEAN_TOKEN=
DIGITALOCEAN_SPACES_KEY=
DIGITALOCEAN_SPACES_SECRET=

# Docker Registry
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=
DOCKER_PASSWORD=

# Raspberry Pi (SSH access)
PI_SSH_HOST=
PI_SSH_USER=pi
PI_SSH_KEY=~/.ssh/id_rsa

# =============================================================================
# SOURCE CONTROL
# =============================================================================

# GitHub (https://github.com/settings/tokens)
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# =============================================================================
# PROJECT MANAGEMENT
# =============================================================================

# Asana (https://app.asana.com/-/developer_console)
ASANA_ACCESS_TOKEN=
ASANA_WORKSPACE_ID=
ASANA_PROJECT_ID=

# Notion (https://www.notion.so/my-integrations)
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_WORKSPACE_ID=

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Clerk (https://dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# =============================================================================
# PAYMENTS
# =============================================================================

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# AI & MACHINE LEARNING
# =============================================================================

# Hugging Face (https://huggingface.co/settings/tokens)
HUGGINGFACE_TOKEN=
HUGGINGFACE_SPACE_ID=

# Open Source Model Registry
MODEL_REGISTRY_URL=
MODEL_AUDIT_KEY=

# =============================================================================
# TUNNEL SERVICES
# =============================================================================

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

# ngrok (https://dashboard.ngrok.com)
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# Tailscale (https://login.tailscale.com/admin/settings/keys)
TAILSCALE_AUTHKEY=
TAILSCALE_TAILNET=

# =============================================================================
# NOTIFICATIONS
# =============================================================================

# Discord (https://discord.com/developers/applications)
DISCORD_WEBHOOK_URL=
DISCORD_BOT_USERNAME=BlackRoad Bot
DISCORD_BOT_AVATAR=
ENABLE_DISCORD=false

# =============================================================================
# VOICE & AUDIO
# =============================================================================

# ElevenLabs (https://elevenlabs.io)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ENABLE_VOICE=false

# =============================================================================
# DATABASE & CACHE
# =============================================================================

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

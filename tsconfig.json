{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "jsx": "react-jsx",
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "src",
    "scripts",
    "lib",
    "components",
    "app",
    "chronicles",
    "vitest.config.ts"
  ],
  "exclude": ["node_modules", "dist", "tests"]
}
